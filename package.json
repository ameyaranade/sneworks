{
  "name": "sneworks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "npx firebase-tools deploy --only hosting,functions",
    "deploy:hosting": "npx firebase-tools deploy --only hosting",
    "deploy:functions": "cd functions && npm run build && cd .. && npx firebase-tools deploy --only functions",
    "deploy:rules": "npx firebase-tools deploy --only firestore:rules",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "emulator": "firebase emulators:start --only auth,firestore"
  },
  "dependencies": {
    "date-fns": "^4.3.0",
    "firebase": "^11.0.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "rrule": "^2.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
